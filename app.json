{
  "expo": {
    "name": "split_the_bill",
    "slug": "split_the_bill",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.ehsaan.splitthebill",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "plugins": [
      "expo-sqlite",
      "expo-secure-store",
      "expo-dev-client",
      [
        "expo-image-picker",
        {
          "photosPermission": "Split the Bill needs access to your photos so you can pick a receipt to scan.",
          "cameraPermission": false,
          "microphonePermission": false
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "buildArchs": [
              "arm64-v8a"
            ]
          }
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "3a413599-b7bd-48ef-a6c7-f2edf0a1c101"
      }
    },
    "owner": "ehsaan1999",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/3a413599-b7bd-48ef-a6c7-f2edf0a1c101"
    }
  }
}
